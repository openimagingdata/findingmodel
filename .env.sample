# AI Model Configuration
# Models use Pydantic AI format: "provider:model-name"
# Supported providers:
#   - openai, anthropic, ollama: standard providers
#   - google, google-gla, google-vertex: Google Gemini (routed to GLA or Vertex based on keys)
#   - gateway/openai, gateway/anthropic: via Pydantic AI Gateway
#   - gateway/google, gateway/google-vertex: Google via Gateway (Vertex AI)
#
# Default: base=openai:gpt-5.4, full=openai:gpt-5.4, small=google-gla:gemini-3-flash-preview
#
# Gateway fallback: If a provider-specific key is missing but PYDANTIC_AI_GATEWAY_API_KEY
# is set, requests are automatically routed through the gateway. This means you can use
# PYDANTIC_AI_GATEWAY_API_KEY as a single key for all providers.
#
# Examples:
# DEFAULT_MODEL=openai:gpt-5.4
# DEFAULT_MODEL=google-gla:gemini-3-flash-preview  # Direct Google AI Studio API
# DEFAULT_MODEL=gateway/google:gemini-3-flash-preview  # Via gateway (Vertex AI)
# DEFAULT_MODEL_FULL=openai:gpt-5.4
# DEFAULT_MODEL_SMALL=openai:gpt-5-mini  # OpenAI-only setup (no Google key needed)
#
# Per-tier reasoning levels (none/minimal/low/medium/high/xhigh):
# DEFAULT_REASONING_SMALL=low
# DEFAULT_REASONING_BASE=none
# DEFAULT_REASONING_FULL=high
#
# Per-agent model overrides (optional, use domain_verb tag names)
# AGENT_MODEL_OVERRIDES__enrich_classify=anthropic:claude-opus-4-6
# AGENT_MODEL_OVERRIDES__edit_instructions=openai:gpt-5.4
# AGENT_MODEL_OVERRIDES__anatomic_select=ollama:llama3

# API Keys (at least one required, depending on your model configuration)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# PYDANTIC_AI_GATEWAY_API_KEY=  # Universal fallback for all cloud providers

# Ollama Configuration (for local/self-hosted models)
# OLLAMA_BASE_URL=http://localhost:11434/v1  # Default local Ollama
# OLLAMA_BASE_URL=http://gpu-server:11434/v1  # Remote Ollama server

# External Services
TAVILY_API_KEY=
# TAVILY_SEARCH_DEPTH=advanced

# DuckDB Database Configuration
# By default, databases are downloaded from manifest.json to platform-specific user data directory
#
# Configuration priority (for both index and anatomic databases):
# 1. If DB_PATH points to existing file (and no URL/hash): use file directly
# 2. If DB_PATH exists AND URL/hash set: verify hash, use file or re-download
# 3. If DB_PATH doesn't exist AND URL/hash set: download using URL/hash
# 4. If nothing specified: download from manifest.json (fallback)
#
# Docker/Production: Pre-mount databases and specify absolute paths
# FINDINGMODEL_DB_PATH=/mnt/data/finding_models.duckdb
# ANATOMIC_DB_PATH=/mnt/data/anatomic_locations.duckdb
#
# Custom Download: Specify URL and hash (both required)
# FINDINGMODEL_REMOTE_DB_URL=https://custom.host/finding_models.duckdb
# FINDINGMODEL_REMOTE_DB_HASH=sha256:def456...
# ANATOMIC_REMOTE_DB_URL=https://custom.host/anatomic_locations.duckdb
# ANATOMIC_REMOTE_DB_HASH=sha256:abc123...
#
# Relative paths: Resolved to user data directory
# FINDINGMODEL_DB_PATH=my_custom_index.duckdb
# ANATOMIC_DB_PATH=my_custom_anatomic.duckdb


# Optional: Logfire observability (for eval tracing and debugging)
# Get token from https://logfire.pydantic.dev/ after creating an account
# LOGFIRE_TOKEN=
# DISABLE_SEND_TO_LOGFIRE=false
# LOGFIRE_VERBOSE=false
